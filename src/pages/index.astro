---
import Root from "$/layouts/minimal.astro";
import Divider from "$/lib/divider.svelte";
import OverscrollTail from "$/lib/overscroll-tail.astro";
import { projects } from "$/projects";
import { ArrowRightIcon } from "@lucide/svelte";
import { format } from "$/lib/date";
import Blurb from "./_blurb.svelte";


import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const posts = allPosts.slice(0, 4);

const latest = posts[0];
---

<Root
  description="Personal site of Jacob with writing, software projects, experiments, and notes on code, fiction, and building things."
>
  <div data-page-content class="content-bg @container">

    <!-- Blurb + Socials -->
    <div class="px-7 py-6 ">
      <Blurb client:load/>
      <div class="flex items-center gap-6 flex-wrap">
        <a
          href="https://github.com/jafupy"
          class="font-mono text-sm text-old-rose transition-colors hover:underline underline-offset-4"
        >
          GitHub
        </a>
        <a
          href="https://x.com/jafupy"
          class="font-mono text-sm text-old-rose transition-colors hover:underline underline-offset-4"
        >
          Twitter
        </a>
        <a
          href="mailto:hello@jafupy.com"
          class="font-mono text-sm text-old-rose transition-colors hover:underline underline-offset-4"
        >
          hello@jafupy.com
        </a>
      </div>
    </div>

    <!-- Featured — bleeds 1rem past card edges -->
    <div
      class="-mx-4 cursor-pointer group"
    >
      <a
        href={`/writing/${latest.data.date.getFullYear()}/${latest.id}`}
        class="p-5 flex flex-col border border-mauve-100/20 rounded-xl bg-mauve-800"
      >
        <div
          class="font-mono text-xs tracking-widest uppercase text-mauve-400 mb-3"
        >
          latest yappery/tangent/ragebait/"blog post"
        </div>
        <h2
          class="font-serif text-2xl leading-snug mb-3 group-hover:text-white transition-colors"
        >
          {latest.data.title}
        </h2>
        <p
          class="text-mauve-400 text-sm leading-relaxed mb-4"
        >
          {latest.data.description}
        </p>
        <div class="w-full flex items-center gap-2.5 pt-1">
          <span
            class="font-mono text-xs text-mauve-400 whitespace-nowrap"
          >
            {format(latest.data.date)}
          </span>
          <Divider />
          <span
            class="inline-flex items-center gap-2 font-mono text-xs text-mauve-400 transition-colors group-hover:text-mauve-300"
          >
            Read
            <ArrowRightIcon class="size-4" />
          </span>
        </div>
      </a>
    </div>

  </div>
  <OverscrollTail />
</Root>

<script>
  import { gsap } from "gsap";

  /**
   * @typedef {object} FeaturedOption
   * @property {string} title
   * @property {string} description
   * @property {string} href
   * @property {string} meta
   * @property {string} cta
   * @property {"writing" | "game"} kind
   */

  const featuredCard = document.querySelector("[data-featured-card]");

  if (featuredCard instanceof HTMLElement) {
    const featuredLink = featuredCard.querySelector("[data-featured-link]");
    const featuredTitle = featuredCard.querySelector("[data-featured-title]");
    const featuredDescription = featuredCard.querySelector(
      "[data-featured-description]",
    );
    const featuredMeta = featuredCard.querySelector("[data-featured-meta]");
    const featuredCta = featuredCard.querySelector("[data-featured-cta]");
    const featuredItems = featuredCard.querySelectorAll("[data-featured-item]");
    const cleanup = new AbortController();
    const featuredOptionsRaw = featuredCard.dataset.featuredOptions;

    function dayKey() {
      const now = new Date();
      const year = now.getFullYear();
      const month = String(now.getMonth() + 1).padStart(2, "0");
      const day = String(now.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    }

    if (
      typeof featuredOptionsRaw === "string" &&
      featuredLink instanceof HTMLAnchorElement &&
      featuredTitle instanceof HTMLElement &&
      featuredDescription instanceof HTMLElement &&
      featuredMeta instanceof HTMLElement &&
      featuredCta instanceof HTMLElement
    ) {
      /** @type {FeaturedOption[]} */
      const featuredOptions = JSON.parse(featuredOptionsRaw);
      const today = dayKey();
      let bucketHash = 0;
      for (let i = 0; i < today.length; i++) {
        bucketHash = (bucketHash * 31 + today.charCodeAt(i)) >>> 0;
      }

      const bucket = bucketHash % 2 === 0 ? "writing" : "game";
      /** @type {FeaturedOption[]} */
      const pool = [];
      for (const option of featuredOptions) {
        if (option.kind === bucket) pool.push(option);
      }

      const fallbackPool = pool.length > 0 ? pool : featuredOptions;
      const featuredKey = `${today}:${bucket}`;
      let featuredHash = 0;
      for (let i = 0; i < featuredKey.length; i++) {
        featuredHash = (featuredHash * 31 + featuredKey.charCodeAt(i)) >>> 0;
      }
      const featured = fallbackPool[featuredHash % fallbackPool.length];

      if (featured) {
        featuredLink.href = featured.href;
        featuredTitle.textContent = featured.title;
        featuredDescription.textContent = featured.description;
        featuredMeta.textContent = featured.meta;
        featuredCta.childNodes[0].textContent = `${featured.cta} `;
      }
    }

    window.addEventListener(
      "cmdk-closed",
      () => {
        gsap.killTweensOf([featuredCard, ...featuredItems]);
        gsap.fromTo(
          featuredCard,
          {
            marginLeft: 0,
            marginRight: 0,
            y: -10,
          },
          {
            marginLeft: "-1rem",
            marginRight: "-1rem",
            y: 0,
            duration: 0.15,
            ease: "power3.out",
            overwrite: "auto",
          },
        );

        gsap.fromTo(
          featuredItems,
          {
            y: 10,
            opacity: 0,
            filter: "blur(10px)",
          },
          {
            y: 0,
            opacity: 1,
            filter: "blur(0px)",
            duration: 0.15,
            ease: "power3.out",
            stagger: 0.04,
            delay: 0.02,
            overwrite: "auto",
          },
        );
      },
      { signal: cleanup.signal },
    );

    window.addEventListener("pagehide", () => cleanup.abort(), {
      once: true,
      signal: cleanup.signal,
    });
  }
</script>

---
import Root from "$/layouts/minimal.astro";
import { GithubIcon, MailOpenIcon, TwitterIcon } from "@lucide/svelte";

import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const latest = posts[0];
---

<Root>
  <div
    class="rounded-t-2xl bg-white/5 border-[0.5px] border-white/13 border-b-0 backdrop-blur-xl"
  >
    <!-- Blurb -->
    <div class="px-7 py-5 border-b border-white/7">
      <p class="text-mauve-100 leading-relaxed">
        I'm <span class="text-old-rose">Jacob</span>, <span
          class="text-old-rose">16</span
        >, from <span class="text-old-rose">southern England</span>. I make
        things with <span class="text-old-rose">code</span>, yap, and play
        guitar. Currently building dev tools in Rust, working on a <span
          class="text-old-rose">dystopian novella</span
        >, and studying for my <span class="text-old-rose">GCSEs</span>.
      </p>
    </div>

    <!-- Socials -->
    <div class="px-7 py-4 flex items-center gap-5">
      <a
        href="https://github.com/jafupy"
        class="flex items-center gap-2 text-mauve-400 hover:text-mauve-100 transition-colors"
      >
        <GithubIcon class="size-4 text-old-rose" />
        <span class="font-mono text-xs">github</span>
      </a>
      <a
        href="https://x.com/@jafupy"
        class="flex items-center gap-2 text-mauve-400 hover:text-mauve-100 transition-colors"
      >
        <TwitterIcon class="size-4 text-old-rose" />
        <span class="font-mono text-xs">twitter</span>
      </a>
      <a
        href="mailto:jacob@jafupy.com"
        class="flex items-center gap-2 text-mauve-400 hover:text-mauve-100 transition-colors"
      >
        <MailOpenIcon class="size-4 text-old-rose" />
        <span class="font-mono text-xs">jacob@jafupy.com</span>
      </a>
    </div>

    <!-- Featured — bleeds 1rem past card edges, stays sharp, between socials and writing -->
    <div class="-mx-4 cursor-pointer group">
      <a
        href={`/writing/${latest.data.date.getFullYear()}/${latest.id}`}
        class="p-5 flex flex-col border border-white/10 rounded-xl bg-mauve-800"
      >
        <div
          class="font-mono text-2xs tracking-widest uppercase text-mauve-400 mb-3"
        >
          featured
        </div>
        <h2
          class="font-serif text-mauve-100 text-2xl leading-snug mb-3 group-hover:text-white transition-colors"
        >
          {latest.data.title}
        </h2>
        <p class="text-mauve-400 text-[14px] leading-relaxed mb-4">
          {latest.data.description}
        </p>
        <div class="w-full flex items-center">
          <span
            class="font-mono text-sm text-mauve-400 group-hover:text-mauve-100 transition-colors"
            >read
          </span><div
            class="size-1 bg-mauve-400 rounded-full mx-2 inline-block"
          >
          </div><span class="text-mauve-400 text-xs font-mono">8 min</span>
        </div>
      </a>
    </div>
    <!-- Writing list -->
    <div
      class="flex items-center justify-between px-7 h-9 border-b border-white/[0.07] font-mono-custom text-[11px] tracking-widest uppercase text-mauve-400"
    >
      Writing
    </div>

    {
      posts.slice(1, 5).map((post: any) => (
        <a
          href={`/writing/${post.data.date.getFullYear()}/${post.id}/`}
          class="flex items-baseline justify-between px-7 py-5 border-b border-white/[0.07] cursor-pointer hover:bg-white/2"
        >
          <div class="flex flex-col gap-1.5">
            <span class="yap:h3 mt-4!  text-mauve-100">{post.data.title}</span>
            <span class="text-sm text-mauve-400">{post.data.description}</span>
          </div>
          <span class="font-mono text-xs text-mauve-400 whitespace-nowrap">
            {
              [
                "Jan",
                "Feb",
                "Mar",
                "Apr",
                "May",
                "Jun",
                "Jul",
                "Aug",
                "Sep",
                "Oct",
                "Nov",
                "Dec",
              ][post.data.date.getMonth()]
            }{" "}
            {post.data.date.getFullYear()}
          </span>
        </a>
      ))
    }

    <div class="flex items-center justify-between px-7 py-5">
      <span class="font-mono-custom text-[12px] text-mauve-400"
        >jacob@jafupy.com</span
      >
      <div class="flex gap-4">
        <span
          class="font-mono-custom text-[11px] text-mauve-400 cursor-pointer hover:text-mauve-100"
          >github ↗</span
        >
        <span
          class="font-mono-custom text-[11px] text-mauve-400 cursor-pointer hover:text-mauve-100"
          >rss ↗</span
        >
      </div>
    </div>
  </div>
</Root>

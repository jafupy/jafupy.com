---
import Root from "$/layouts/minimal.astro";
import { getPostHref, sortPostsByDate } from "$/lib/blog";
import { format } from "$/lib/date";
import OverscrollTail from "$/lib/overscroll-tail.astro";
import { getCollection } from "astro:content";

const posts = sortPostsByDate(await getCollection("blog"));
---

<Root
  title="Writing"
  description="Essays, notes, and blog posts by Jacob on programming, tools, and whatever else is worth writing down."
>
  <div data-page-content class="content-bg">
    {
      posts.map((post) => (
        <a
          href={getPostHref(post)}
          class="flex items-baseline justify-between px-7 py-5 border-b border-mauve-100/20 cursor-pointer hover:bg-white/2"
        >
          <div class="flex flex-col gap-1.5">
            <span class="yap:h3">{post.data.title}</span>
            <span class="text-sm text-mauve-400">{post.data.description}</span>
          </div>
          <span class="font-mono text-xs text-mauve-400 whitespace-nowrap">
            {format(post.data.date)}
          </span>
        </a>
      ))
    }
  </div>
  <OverscrollTail />
</Root>

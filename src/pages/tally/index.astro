---
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/brygada-1918";
import "@fontsource-variable/jetbrains-mono";
import { CopyIcon } from "@lucide/svelte";
import SeoHead from "$/components/seo-head.astro";

import "$/styles/global.css";

const installCommand = `curl -fsSL https://jafupy.com/tally.sh | sh
tally .`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <SeoHead
      title="Tally"
      description="Tally is a fast, over-optimized cloc-style counter for codebases."
    />
  </head>
  <body
    class="min-w-[320px] min-h-screen bg-[var(--page-bg)] text-[var(--body-text)] font-sans antialiased"
  >
    <main
      class="mx-auto flex min-h-screen w-full max-w-3xl flex-col px-6 py-8 sm:px-8 sm:py-12"
    >
      <header class="mb-14 flex items-center justify-between gap-6 text-sm">
        <a
          class="text-xl font-semibold text-[var(--heading-text)] no-underline"
          href="/tally/">Tally</a
        >
        <nav class="flex gap-5 text-[var(--muted-text)]">
          <a href="#install">Install</a>
          <a href="https://github.com/jafupy/tally">GitHub</a>
        </nav>
      </header>

      <section
        class="tally-copy max-w-none text-[var(--body-text)] leading-[1.7] [container-type:inline-size]"
      >
        <h1
          class="mb-[0.45em] mt-[0.6em] font-serif text-[clamp(1.65rem,1.45rem+0.95vw,1.934rem)] font-semibold leading-[1.15] text-[var(--heading-text)]"
        >
          An over-optimized cloc clone.
        </h1>
        <p class="mb-0">
          Tally counts files, lines, blanks, comments, and code. It walks a tree, guesses the
          language, prints a table, and stops.
        </p>

        <pre
          class="tally-preview my-5 overflow-x-auto rounded-lg border border-[color-mix(in_oklch,var(--heading-text)_10%,transparent)] bg-[var(--pre-bg)] p-4 font-mono leading-[1.7]"
        ><code>$ tally .
Language Files Lines Blank Comment Code
-------- ----- ----- ----- ------- ----
Rust         6  1235   184       4 1047
TOML         9   972   146       2  824
Text         1   200    73       0  127
-------- ----- ----- ----- ------- ----
Total       16  2407   403       6 1998</code></pre>

        <h2
          id="install"
          class="mb-[0.45em] mt-[0.8em] font-serif text-[clamp(1.5rem,1.34rem+0.75vw,1.695rem)] font-normal leading-[1.2] text-[var(--heading-text)]"
        >
          Install
        </h2>
        <div
          class="my-5 overflow-hidden rounded-lg border border-[var(--card-border)] bg-[var(--card-bg)]"
        >
          <div
            class="flex min-h-11 items-center justify-between gap-4 border-b border-[var(--card-border)] py-2 pl-4 pr-2 text-sm leading-none text-[var(--muted-text)]"
          >
            <span>Shell</span>
            <button
              class="inline-flex h-8 min-w-23 cursor-pointer items-center justify-center gap-1.5 rounded-md bg-[var(--button-bg)] text-sm font-medium leading-none text-[var(--heading-text)] hover:bg-[var(--button-hover-bg)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-old-rose data-[copied=true]:text-old-rose"
              type="button"
              data-copy-install
              aria-label="Copy install command"
            >
              <CopyIcon class="size-4 stroke-2" aria-hidden="true" />
              <span class="copy-label">Copy</span>
            </button>
          </div>
          <pre
            class="m-0 overflow-x-auto bg-transparent p-4 font-mono text-sm leading-[1.7] text-[var(--heading-text)]"
          ><code data-install-command>{installCommand}</code></pre>
        </div>

        <p class="mb-0">
          Downloads the latest release and installs it to <code>~/.local/bin</code>.
        </p>
        <p class="mb-0 mt-[0.85em]">
          <a
            class="text-old-rose underline decoration-1 underline-offset-2 hover:decoration-2"
            href="https://github.com/jafupy/tally">Source on GitHub.</a
          >
        </p>
      </section>

      <footer class="mt-auto pt-16 text-sm text-[var(--muted-text)]">
        <p>GPL-3.0-or-later. Counts lines. Tries very hard.</p>
      </footer>
    </main>

    <script>
      const button = document.querySelector("[data-copy-install]");
      const command = document.querySelector("[data-install-command]");
      const label = button?.querySelector(".copy-label");

      const copyText = async (text: string) => {
        if (navigator.clipboard) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        document.body.append(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
      };

      button?.addEventListener("click", async () => {
        await copyText(command?.textContent?.trim() ?? "");
        if (!label || !(button instanceof HTMLElement)) return;

        label.textContent = "Copied";
        button.dataset.copied = "true";

        window.setTimeout(() => {
          label.textContent = "Copy";
          delete button.dataset.copied;
        }, 1600);
      });
    </script>
  </body>
</html>

<style>
  :root {
    --page-bg: var(--color-mauve-50);
    --body-text: var(--color-mauve-800);
    --heading-text: var(--color-mauve-950);
    --muted-text: var(--color-mauve-600);
    --inline-code-bg: var(--color-mauve-100);
    --pre-bg: var(--color-mauve-100);
    --card-bg: var(--color-mauve-50);
    --card-border: var(--color-mauve-300);
    --button-bg: var(--color-mauve-100);
    --button-hover-bg: var(--color-mauve-200);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --page-bg: var(--color-mauve-950);
      --body-text: var(--color-mauve-300);
      --heading-text: var(--color-mauve-100);
      --muted-text: var(--color-mauve-400);
      --inline-code-bg: var(--color-mauve-800);
      --pre-bg: var(--color-mauve-900);
      --card-bg: var(--color-mauve-900);
      --card-border: var(--color-mauve-700);
      --button-bg: var(--color-mauve-800);
      --button-hover-bg: var(--color-mauve-700);
    }
  }

  html {
    color-scheme: light dark;
    scroll-behavior: smooth;
  }

  a {
    text-underline-offset: 2px;
  }

  :global(.tally-copy code:not(pre *)) {
    background-color: var(--inline-code-bg);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 2px 4px;
  }

  .tally-preview {
    font-size: min(1rem, calc((100vw - 3rem) / 25));
    font-size: min(1rem, calc((100cqw - 2rem) / 25));
  }
</style>

---
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/brygada-1918";
import "@fontsource-variable/jetbrains-mono";
import { CopyIcon } from "@lucide/svelte";
import SeoHead from "$/components/seo-head.astro";

import "$/styles/global.css";
---

<!doctype html>
<html lang="en" class="scroll-smooth scheme-light-dark">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <SeoHead
      title="Tally"
      description="Tally is a fast, over-optimized line counter for codebases."
    />
  </head>
  <body
    class="min-w-[320px] min-h-screen bg-mauve-50 dark:bg-mauve-950 text-mauve-800 dark:text-mauve-300 font-sans antialiased"
  >
    <main
      class="mx-auto flex min-h-screen w-full max-w-3xl flex-col px-6 py-8 sm:px-8 sm:py-12"
    >
      <header class="mb-14 flex items-center justify-between gap-6 text-sm">
        <a
          class="text-xl font-semibold text-mauve-950 dark:text-mauve-100 no-underline"
          href="/tally/">Tally</a
        >
        <nav class="flex gap-5 text-mauve-600 dark:text-mauve-400">
          <a href="#install" class="underline-offset-2">Install</a>
          <a href="https://github.com/jafupy/tally" class="underline-offset-2">GitHub</a>
        </nav>
      </header>

      <section
        class="max-w-none leading-[1.7] @container"
      >
        <h1
          class="mb-[0.45em] mt-[0.6em] font-serif text-[clamp(1.65rem,1.45rem+0.95vw,1.934rem)] font-semibold leading-[1.15] text-mauve-950 dark:text-mauve-100"
        >
          A line counter for codebases.
        </h1>
        <p class="mb-0">
          Tally counts files, lines, blanks, comments, and code, sorted by language.
        </p>

        <pre
          class="my-5 overflow-x-auto rounded-lg border border-mauve-950/10 dark:border-mauve-100/10 bg-mauve-100 dark:bg-mauve-900 p-4 font-mono leading-[1.7] text-[min(0.875rem,calc((87.5cqw-2rem)/25))]"
        ><code>$ tally .
Language Files Lines Blank Comment Code
-------- ----- ----- ----- ------- ----
Rust         6  1235   184       4 1047
TOML         9   972   146       2  824
Text         1   200    73       0  127
-------- ----- ----- ----- ------- ----
Total       16  2407   403       6 1998</code></pre>

        <h2
          id="install"
          class="mb-[0.45em] mt-[0.8em] font-serif text-[clamp(1.5rem,1.34rem+0.75vw,1.695rem)] font-normal leading-[1.2] text-mauve-950 dark:text-mauve-100"
        >
          Install
        </h2>
        <div
          id="install-box"
          class="my-5 overflow-hidden rounded-lg border border-mauve-300 dark:border-mauve-700 bg-mauve-50 dark:bg-mauve-900 ring-0 ring-blue-400 dark:ring-blue-600 transition-shadow duration-300"
        >
          <div
            class="flex min-h-11 items-center justify-between gap-4 border-b border-mauve-300 dark:border-mauve-700 py-2 pl-4 pr-2 text-sm leading-none text-mauve-600 dark:text-mauve-400"
          >
            <span>Shell</span>
            <button
              class="inline-flex h-8 min-w-23 cursor-pointer items-center justify-center gap-1.5 rounded-md bg-mauve-100 dark:bg-mauve-800 text-sm font-medium leading-none text-mauve-950 dark:text-mauve-100 hover:bg-mauve-200 dark:hover:bg-mauve-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-old-rose data-[copied=true]:text-old-rose"
              type="button"
              data-copy-install
              aria-label="Copy install command"
            >
              <CopyIcon class="size-4 stroke-2" aria-hidden="true" />
              <span class="copy-label">Copy</span>
            </button>
          </div>
          <pre
            class="m-0 overflow-x-auto bg-transparent p-4 font-mono text-sm leading-[1.7] text-mauve-950 dark:text-mauve-100"
          ><code data-install-command><span class="text-emerald-600 dark:text-emerald-400">curl</span> -fsSL https://jafupy.com/tally.sh | <span class="text-emerald-600 dark:text-emerald-400">sh</span>
<span class="text-emerald-600 dark:text-emerald-400">tally</span> .</code></pre>
        </div>

        <p class="mb-0">
          Installs to <code
            class="rounded-sm bg-mauve-100 dark:bg-mauve-800 px-1 py-0.5 font-mono text-sm"
            >~/.local/bin</code
          >.
        </p>
      </section>

      <footer class="mt-auto pt-16 text-sm text-mauve-600 dark:text-mauve-400">
        <p>GPL-3.0-or-later. Counts faster than anyone asked it to.</p>
      </footer>
    </main>

    <script>
      const button = document.querySelector("[data-copy-install]");
      const command = document.querySelector("[data-install-command]");
      const label = button?.querySelector(".copy-label");
      const installLink = document.querySelector('a[href="#install"]');
      const installBox = document.querySelector<HTMLElement>("#install-box");

      const copyText = async (text: string) => {
        if (navigator.clipboard) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.left = "-9999px";
        document.body.append(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
      };

      button?.addEventListener("click", async () => {
        await copyText(command?.textContent?.trim() ?? "");
        if (!label || !(button instanceof HTMLElement)) return;

        label.textContent = "Copied";
        button.dataset.copied = "true";

        window.setTimeout(() => {
          label.textContent = "Copy";
          delete button.dataset.copied;
        }, 1600);
      });

      const highlightInstallBox = () => {
        if (!installBox) return;
        installBox.classList.add("ring-4");
        window.setTimeout(() => {
          installBox.classList.remove("ring-4");
        }, 1200);
      };

      installLink?.addEventListener("click", () => {
        window.setTimeout(highlightInstallBox, 400);
      });

      if (window.location.hash === "#install") {
        highlightInstallBox();
      }
    </script>
  </body>
</html>

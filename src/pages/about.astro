---
import Root from "$/layouts/minimal.astro";
import { GithubIcon, MailOpenIcon, TwitterIcon } from "@lucide/svelte";

import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const latest = posts[0];
---

<Root title="About">
  <div
    class="rounded-t-2xl bg-white/5 border-[0.5px] border-white/13 border-b-0 backdrop-blur-xl"
  >
    <!-- Blurb -->
    <div class="px-7 py-5 border-b border-white/7 yap">
      <p>
        I'm <span class="text-old-rose">Jacob</span> — a 16-year-old polish idiot
        who yaps, yaps in <span class="text-old-rose">code</span> and makes noise
        with a <span class="text-old-rose">guitar</span> in <span
          class="text-old-rose">southern England</span
        >.
      </p>
      <p>
        I write mostly <span class="text-old-rose">Rust</span> and <span
          class="text-old-rose">J|TS</span
        >. Currently I'm working on <span class="text-old-rose">Crumbs</span>, a
        lightweight process orchestrator for <span class="text-old-rose"
          >macOS</span
        > that stops me running a dozen servers at once, and <span
          class="text-old-rose">Spread</span
        >, an email management tool that will be its first plugin.
      </p>
      <p>
        I keep a <span class="text-old-rose">blog</span> here — mostly technical,
        occasionally not. I also write
        <span class="text-old-rose">fiction</span>. My current project is <span
          class="text-old-rose">Five</span
        >, a dystopian novella about a paranoid unnamed protagonist and a
        resistance cell called <span class="text-old-rose">Dead Hand</span>,
        which stemmed from a <span class="text-old-rose">GCSE</span> English Language
        Paper 1 Q5 prompt I did at school. It lives in my <span
          class="text-old-rose">Obsidian</span
        > vault alongside countless pages of worldbuilding and rambling for other
        fantasy projects I've been working on for years.
      </p>
      <p>
        I play <span class="text-old-rose">fingerstyle guitar</span>. I'm
        working on an original piece called
        <span class="text-old-rose">Masquerade</span> in open <span
          class="text-old-rose">Gm tuning</span
        >.
      </p>
      <p>
        I'm studying <span class="text-old-rose">CS</span>, <span
          class="text-old-rose">Physics</span
        >, and <span class="text-old-rose">Maths</span> for my GCSEs.
      </p>
    </div>

    <div class="flex items-center justify-between px-7 py-5">
      <span class="font-mono-custom text-[12px] text-mauve-400"
        >jacob@jafupy.com</span
      >
      <div class="flex gap-4">
        <span
          class="font-mono-custom text-[11px] text-mauve-400 cursor-pointer hover:text-mauve-100"
          >github ↗</span
        >
        <span
          class="font-mono-custom text-[11px] text-mauve-400 cursor-pointer hover:text-mauve-100"
          >rss ↗</span
        >
      </div>
    </div>
  </div>
</Root>

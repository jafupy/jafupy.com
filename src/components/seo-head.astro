---
import {
  buildSeoMetadata,
  SITE_AUTHOR,
  SITE_NAME,
  type SeoProps,
} from "$/lib/seo";

const {
  canonical,
  description,
  jsonLd,
  modifiedTime,
  ogType,
  pageTitle,
  publishedTime,
  socialImage,
} = buildSeoMetadata({
  props: Astro.props as SeoProps,
  currentUrl: Astro.url,
  configuredSite: Astro.site,
  isDev: import.meta.env.DEV,
});
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content="index,follow" />
<meta name="author" content={SITE_AUTHOR} />
<meta name="theme-color" content="#14121a" />
<link rel="canonical" href={canonical.toString()} />
<link rel="icon" href="/favicon.png" />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical.toString()} />
<meta property="og:image" content={socialImage.toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImage.toString()} />
<meta name="twitter:creator" content="@jafupy" />
{
  publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )
}
{
  modifiedTime && (
    <meta property="article:modified_time" content={modifiedTime} />
  )
}
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(jsonLd)}
/>

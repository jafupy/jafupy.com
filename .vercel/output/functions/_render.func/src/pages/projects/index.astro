---
import Root from "$/layouts/minimal.astro";
import OverscrollTail from "$/lib/overscroll-tail.astro";
import { projects } from "$/projects";
---

<Root
  title="Projects"
  description="Projects, experiments, and playable things by Jacob."
>
  <div data-page-content class="content-bg">
    <div>
      <div class="flex items-center px-7 h-9 border-b border-mauve-100/20">
        <span class="font-mono text-xs tracking-widest uppercase text-mauve-400 shrink-0">Projects</span>
      </div>
      <div class="grid grid-cols-2">
        {
          projects.map((project, i) => (
            <a
              href={project.href}
              class:list={[
                "grid grid-rows-subgrid row-span-3 px-6 hover:bg-white/2 transition-colors",
                i % 2 === 0 ? "border-r border-mauve-100/20" : "",
              ]}
            >
              <h3 class="font-serif text-2xl leading-snug pt-5 text-mauve-50">{project.title}</h3>
              <time class="font-mono text-xs text-mauve-400 mt-1">
                Emulator
              </time>
              <p class="text-sm text-mauve-200 leading-relaxed mt-2 pb-5">{project.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </div>
  <OverscrollTail />
</Root>

---
// Syllabary — a word generator inspired by Awkwords
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Syllabary</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:       #0e0d0b;
      --surface:  #161410;
      --border:   #2e2b24;
      --border2:  #3d3830;
      --text:     #e8e0d0;
      --muted:    #7a7060;
      --amber:    #c8973a;
      --amber-dim:#8a6520;
      --amber-glow: rgba(200,151,58,0.08);
      --red:      #c45c4a;
      --mono: 'JetBrains Mono', 'Fira Code', monospace;
      --serif: 'Libre Baskerville', Georgia, serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { font-size: 15px; background: var(--bg); color: var(--text); }

    body {
      font-family: var(--mono);
      min-height: 100vh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      background:
        radial-gradient(ellipse 80% 40% at 50% -10%, rgba(200,151,58,0.06) 0%, transparent 70%),
        var(--bg);
    }

    /* ── Header ── */
    header {
      padding: 2.5rem 3rem 2rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: baseline;
      gap: 1.2rem;
    }

    .wordmark {
      font-family: var(--serif);
      font-size: 1.7rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--text);
    }

    .wordmark span {
      color: var(--amber);
    }

    .tagline {
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .version {
      margin-left: auto;
      font-size: 0.7rem;
      color: var(--amber-dim);
      letter-spacing: 0.08em;
      font-weight: 500;
    }

    /* ── Layout ── */
    main {
      display: grid;
      grid-template-columns: 420px 1fr;
      min-height: 0;
    }

    /* ── Panel ── */
    .panel {
      padding: 2.5rem 2.5rem;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 2rem;
      overflow-y: auto;
    }

    .section-label {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--amber);
      font-weight: 700;
      margin-bottom: 0.9rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── Subpatterns ── */
    .subpatterns {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .subpattern-row {
      display: grid;
      grid-template-columns: 2.2rem auto 1fr;
      align-items: center;
      gap: 0.6rem;
      animation: fadeIn 0.3s ease forwards;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-4px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .sp-name {
      width: 2.2rem;
      height: 2.2rem;
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 4px;
      text-align: center;
      font-family: var(--mono);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--amber);
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      caret-color: var(--amber);
      text-transform: uppercase;
      padding: 0;
    }

    .sp-name:focus {
      outline: none;
      border-color: var(--amber-dim);
      background: var(--amber-glow);
    }

    .sp-equals {
      font-size: 0.7rem;
      color: var(--muted);
      user-select: none;
      text-align: center;
    }

    .sp-value {
      height: 2.2rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0 0.75rem;
      font-family: var(--mono);
      font-size: 0.8rem;
      color: var(--text);
      transition: border-color 0.15s, background 0.15s;
      caret-color: var(--amber);
    }

    .sp-value:focus {
      outline: none;
      border-color: var(--amber-dim);
      background: var(--amber-glow);
    }

    .sp-value::placeholder {
      color: var(--muted);
    }

    .remove-sp {
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 1rem;
      padding: 0 0.2rem;
      line-height: 1;
      transition: color 0.15s;
      font-family: var(--mono);
    }

    .remove-sp:hover { color: var(--red); }

    .add-sp {
      background: none;
      border: 1px dashed var(--border2);
      border-radius: 4px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      padding: 0.5rem 1rem;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
      width: 100%;
    }

    .add-sp:hover {
      border-color: var(--amber-dim);
      color: var(--amber);
      background: var(--amber-glow);
    }

    /* ── Pattern ── */
    .pattern-wrap {
      position: relative;
    }

    .pattern-input {
      width: 100%;
      height: 3rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0 1rem;
      font-family: var(--mono);
      font-size: 1rem;
      font-weight: 500;
      color: var(--text);
      transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
      caret-color: var(--amber);
      letter-spacing: 0.04em;
    }

    .pattern-input:focus {
      outline: none;
      border-color: var(--amber);
      background: var(--amber-glow);
      box-shadow: 0 0 0 3px rgba(200,151,58,0.08);
    }

    .pattern-hint {
      margin-top: 0.6rem;
      font-size: 0.65rem;
      color: var(--muted);
      line-height: 1.6;
    }

    .pattern-hint code {
      color: var(--amber-dim);
      font-family: var(--mono);
    }

    /* ── Options ── */
    .options {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .option-row {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .opt-label {
      font-size: 0.72rem;
      color: var(--muted);
      flex: 1;
      cursor: pointer;
    }

    .word-count-wrap {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .word-count-input {
      width: 4.5rem;
      height: 2rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0 0.5rem;
      font-family: var(--mono);
      font-size: 0.8rem;
      color: var(--text);
      text-align: right;
      caret-color: var(--amber);
      transition: border-color 0.15s;
    }

    .word-count-input:focus {
      outline: none;
      border-color: var(--amber-dim);
    }

    /* Custom checkbox */
    .checkbox-wrap {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      cursor: pointer;
    }

    .checkbox-wrap input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 1.1rem;
      height: 1.1rem;
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 3px;
      position: relative;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      flex-shrink: 0;
    }

    .checkbox-wrap input[type="checkbox"]:checked {
      background: var(--amber);
      border-color: var(--amber);
    }

    .checkbox-wrap input[type="checkbox"]:checked::after {
      content: '';
      position: absolute;
      top: 2px; left: 3px;
      width: 5px; height: 8px;
      border: 2px solid var(--bg);
      border-top: none;
      border-left: none;
      transform: rotate(45deg);
    }

    /* ── Generate button ── */
    .generate-btn {
      width: 100%;
      height: 3rem;
      background: var(--amber);
      border: none;
      border-radius: 6px;
      font-family: var(--mono);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--bg);
      cursor: pointer;
      transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
      position: relative;
      overflow: hidden;
    }

    .generate-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0.08);
      opacity: 0;
      transition: opacity 0.15s;
    }

    .generate-btn:hover { background: #d4a442; box-shadow: 0 4px 20px rgba(200,151,58,0.25); }
    .generate-btn:hover::after { opacity: 1; }
    .generate-btn:active { transform: translateY(1px); }

    .generate-btn.loading {
      pointer-events: none;
    }

    .generate-btn.loading .btn-text {
      opacity: 0;
    }

    .generate-btn.loading::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 1.2rem; height: 1.2rem;
      margin: -0.6rem;
      border: 2px solid rgba(14,13,11,0.3);
      border-top-color: var(--bg);
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Output ── */
    .output {
      display: flex;
      flex-direction: column;
      padding: 2.5rem 3rem;
      overflow: hidden;
    }

    .output-header {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .output-title {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--amber);
      font-weight: 700;
    }

    .output-meta {
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    .output-actions {
      margin-left: auto;
      display: flex;
      gap: 0.5rem;
    }

    .action-btn {
      background: none;
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.35rem 0.7rem;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }

    .action-btn:hover {
      border-color: var(--amber-dim);
      color: var(--amber);
    }

    .word-grid {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-wrap: wrap;
      align-content: flex-start;
      gap: 0.35rem 0.75rem;
      padding-right: 0.5rem;
    }

    .word-grid.newline {
      flex-direction: column;
      flex-wrap: nowrap;
    }

    .word-grid::-webkit-scrollbar { width: 4px; }
    .word-grid::-webkit-scrollbar-track { background: transparent; }
    .word-grid::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

    .word-item {
      font-family: var(--mono);
      font-size: 0.9rem;
      color: var(--text);
      padding: 0.2rem 0.4rem;
      border-radius: 3px;
      cursor: default;
      transition: background 0.1s, color 0.1s;
      line-height: 1.5;
      animation: wordAppear 0.2s ease forwards;
    }

    @keyframes wordAppear {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    .word-item:hover {
      background: var(--amber-glow);
      color: var(--amber);
    }

    .empty-state {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      color: var(--muted);
    }

    .empty-state .glyph {
      font-family: var(--serif);
      font-size: 4rem;
      color: var(--border2);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .empty-state p {
      font-size: 0.72rem;
      letter-spacing: 0.06em;
    }

    /* ── Error ── */
    .error-msg {
      background: rgba(196,92,74,0.1);
      border: 1px solid rgba(196,92,74,0.25);
      border-radius: 4px;
      padding: 0.6rem 0.9rem;
      font-size: 0.72rem;
      color: var(--red);
      margin-top: 0.75rem;
      display: none;
    }

    .error-msg.visible { display: block; }

    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 0.9rem 3rem;
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .footer-note {
      font-size: 0.62rem;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    .kbd {
      display: inline-block;
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 3px;
      padding: 0 0.3rem;
      font-family: var(--mono);
      font-size: 0.58rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── Scrollbar global ── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      header { padding: 1.5rem; }
      main { grid-template-columns: 1fr; }
      .panel { border-right: none; border-bottom: 1px solid var(--border); }
      .output { padding: 1.5rem; }
      footer { padding: 0.9rem 1.5rem; }
    }
  </style>
</head>
<body>

<header>
  <h1 class="wordmark">Syl<span>·</span>la<span>·</span>ba<span>·</span>ry</h1>
  <p class="tagline">phoneme word generator</p>
  <span class="version">v2.0</span>
</header>

<main>
  <!-- ── Left panel ── -->
  <aside class="panel">

    <div>
      <div class="section-label">Subpatterns</div>
      <div class="subpatterns" id="subpatternsContainer">
        <!-- rows injected by JS -->
      </div>
      <button class="add-sp" id="addSpBtn" style="margin-top:0.6rem">+ add subpattern</button>
    </div>

    <div>
      <div class="section-label">Pattern</div>
      <div class="pattern-wrap">
        <input
          type="text"
          class="pattern-input"
          id="patternInput"
          value="CV(CV)(N)"
          spellcheck="false"
          autocomplete="off"
        />
      </div>
      <p class="pattern-hint">
        Uppercase letters reference subpatterns. <code>(X)</code> = optional (50%). Lowercase = literal.<br>
        e.g. <code>CV(CV)</code> → consonant-vowel syllable, optional second syllable.
      </p>
      <div class="error-msg" id="errorMsg"></div>
    </div>

    <div>
      <div class="section-label">Options</div>
      <div class="options">
        <div class="option-row word-count-wrap">
          <label class="opt-label" for="wordCount">words to generate</label>
          <input type="number" class="word-count-input" id="wordCount" value="100" min="1" max="9999" />
        </div>
        <label class="checkbox-wrap">
          <input type="checkbox" id="filterDuplicates" checked />
          <span class="opt-label">filter duplicates</span>
        </label>
        <label class="checkbox-wrap">
          <input type="checkbox" id="newlineEach" />
          <span class="opt-label">one word per line</span>
        </label>
      </div>
    </div>

    <button class="generate-btn" id="generateBtn">
      <span class="btn-text">Generate</span>
    </button>

  </aside>

  <!-- ── Output ── -->
  <section class="output">
    <div class="output-header">
      <span class="output-title">Output</span>
      <span class="output-meta" id="outputMeta"></span>
      <div class="output-actions">
        <button class="action-btn" id="copyBtn">Copy</button>
        <button class="action-btn" id="saveBtn">Save .txt</button>
      </div>
    </div>

    <div class="word-grid" id="wordGrid">
      <div class="empty-state">
        <div class="glyph">ꝏ</div>
        <p>configure subpatterns and generate</p>
      </div>
    </div>
  </section>
</main>

<footer>
  <span class="footer-note">
    Press <span class="kbd">⌘ Enter</span> or <span class="kbd">Ctrl Enter</span> to generate
  </span>
</footer>

<script>
  // ── Default subpatterns ──
  const DEFAULT_SUBPATTERNS = [
    { name: 'V', value: 'a/e/o/y/i' },
    { name: 'C', value: 'p/t/k/b/d/g/m/n/r/w/h/l/ł/f/j' },
    { name: 'S', value: 'sz/cz/szcz/zs/dz/dż/zh' },
    { name: 'Z', value: 'ś/ć/dż/ń/rz' },
    { name: 'N', value: 'm/n/ŋ' },
  ];

  const container   = document.getElementById('subpatternsContainer');
  const addSpBtn    = document.getElementById('addSpBtn');
  const patternInput= document.getElementById('patternInput');
  const wordCount   = document.getElementById('wordCount');
  const filterDups  = document.getElementById('filterDuplicates');
  const newlineEach = document.getElementById('newlineEach');
  const generateBtn = document.getElementById('generateBtn');
  const wordGrid    = document.getElementById('wordGrid');
  const outputMeta  = document.getElementById('outputMeta');
  const errorMsg    = document.getElementById('errorMsg');
  const copyBtn     = document.getElementById('copyBtn');
  const saveBtn     = document.getElementById('saveBtn');

  // ── Render subpattern rows ──
  function createRow(name = '', value = '') {
    const row = document.createElement('div');
    row.className = 'subpattern-row';

    const nameInput = document.createElement('input');
    nameInput.type = 'text';
    nameInput.className = 'sp-name';
    nameInput.value = name;
    nameInput.maxLength = 1;
    nameInput.placeholder = '?';
    nameInput.addEventListener('input', () => {
      nameInput.value = nameInput.value.toUpperCase().slice(-1);
    });

    const eq = document.createElement('span');
    eq.className = 'sp-equals';
    eq.textContent = '=';

    const valInput = document.createElement('input');
    valInput.type = 'text';
    valInput.className = 'sp-value';
    valInput.value = value;
    valInput.placeholder = 'a/b/c  (separate with /)';
    valInput.spellcheck = false;

    const removeBtn = document.createElement('button');
    removeBtn.className = 'remove-sp';
    removeBtn.textContent = '×';
    removeBtn.title = 'Remove';
    removeBtn.addEventListener('click', () => row.remove());

    row.appendChild(nameInput);
    row.appendChild(eq);
    row.appendChild(valInput);
    row.appendChild(removeBtn);
    container.appendChild(row);
    return row;
  }

  DEFAULT_SUBPATTERNS.forEach(sp => createRow(sp.name, sp.value));
  addSpBtn.addEventListener('click', () => {
    const row = createRow();
    row.querySelector('.sp-name').focus();
  });

  // ── Parse subpatterns ──
  function getSubpatterns() {
    const map = {};
    container.querySelectorAll('.subpattern-row').forEach(row => {
      const name = row.querySelector('.sp-name').value.trim().toUpperCase();
      const val  = row.querySelector('.sp-value').value.trim();
      if (name && val) {
        map[name] = val.split('/').filter(Boolean);
      }
    });
    return map;
  }

  // ── Pattern parser ──
  // Tokenizes pattern into a list of:
  //   { type: 'ref', name }   — uppercase letter subpattern ref
  //   { type: 'lit', ch }     — literal character
  //   { type: 'opt', tokens } — optional group
  function parsePattern(pattern) {
    const tokens = [];
    let i = 0;

    function parseGroup(end) {
      const group = [];
      while (i < pattern.length) {
        const ch = pattern[i];
        if (ch === end) { i++; break; }
        if (ch === '(') {
          i++;
          const inner = parseGroup(')');
          group.push({ type: 'opt', tokens: inner });
        } else if (ch >= 'A' && ch <= 'Z') {
          group.push({ type: 'ref', name: ch });
          i++;
        } else {
          group.push({ type: 'lit', ch });
          i++;
        }
      }
      return group;
    }

    return parseGroup(null);
  }

  // ── Generate one word ──
  function generateWord(tokens, subpatterns) {
    let result = '';
    for (const tok of tokens) {
      if (tok.type === 'ref') {
        const pool = subpatterns[tok.name];
        if (pool && pool.length) {
          result += pool[Math.floor(Math.random() * pool.length)];
        } else {
          result += tok.name; // literal fallback
        }
      } else if (tok.type === 'lit') {
        result += tok.ch;
      } else if (tok.type === 'opt') {
        if (Math.random() < 0.5) {
          result += generateWord(tok.tokens, subpatterns);
        }
      }
    }
    return result;
  }

  // ── Main generate ──
  function generate() {
    errorMsg.classList.remove('visible');
    const subpatterns = getSubpatterns();
    const pattern = patternInput.value.trim();
    const count   = Math.min(Math.max(parseInt(wordCount.value) || 100, 1), 9999);
    const dedupe  = filterDups.checked;
    const newline = newlineEach.checked;

    if (!pattern) {
      showError('Pattern cannot be empty.');
      return;
    }

    let tokens;
    try { tokens = parsePattern(pattern); }
    catch (e) { showError('Pattern syntax error.'); return; }

    generateBtn.classList.add('loading');

    // Use setTimeout to let the loading UI paint
    setTimeout(() => {
      const seen = new Set();
      const words = [];
      const maxAttempts = count * 20;
      let attempts = 0;

      while (words.length < count && attempts < maxAttempts) {
        const word = generateWord(tokens, subpatterns);
        attempts++;
        if (!word) continue;
        if (dedupe && seen.has(word)) continue;
        seen.add(word);
        words.push(word);
      }

      if (words.length === 0) {
        showError('Could not generate any words. Check your pattern and subpatterns.');
        generateBtn.classList.remove('loading');
        return;
      }

      // Render
      wordGrid.innerHTML = '';
      wordGrid.className = 'word-grid' + (newline ? ' newline' : '');
      outputMeta.textContent = `${words.length} word${words.length !== 1 ? 's' : ''}`;

      words.forEach((word, idx) => {
        const el = document.createElement('span');
        el.className = 'word-item';
        el.textContent = word;
        el.style.animationDelay = `${Math.min(idx, 40) * 8}ms`;
        el.title = 'Click to copy';
        el.addEventListener('click', () => {
          navigator.clipboard.writeText(word).catch(() => {});
        });
        wordGrid.appendChild(el);
      });

      generateBtn.classList.remove('loading');
    }, 30);
  }

  function showError(msg) {
    errorMsg.textContent = msg;
    errorMsg.classList.add('visible');
  }

  // ── Copy all ──
  copyBtn.addEventListener('click', () => {
    const words = [...wordGrid.querySelectorAll('.word-item')].map(el => el.textContent);
    if (!words.length) return;
    navigator.clipboard.writeText(words.join(newlineEach.checked ? '\n' : ' ')).then(() => {
      const orig = copyBtn.textContent;
      copyBtn.textContent = 'Copied!';
      setTimeout(() => (copyBtn.textContent = orig), 1500);
    });
  });

  // ── Save ──
  saveBtn.addEventListener('click', () => {
    const words = [...wordGrid.querySelectorAll('.word-item')].map(el => el.textContent);
    if (!words.length) return;
    const blob = new Blob([words.join('\n')], { type: 'text/plain' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'syllabary-words.txt';
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── Keyboard shortcut ──
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
      e.preventDefault();
      generate();
    }
  });

  generateBtn.addEventListener('click', generate);
</script>
</body>
</html>
